# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.
#
# API keys set here take priority over any values in settings.yaml.
# Service URLs and non-sensitive config still live in settings.yaml.

TAUTULLI_API_KEY=
SABNZBD_API_KEY=
OVERSEERR_API_KEY=
TMDB_API_KEY=

# Cloudflare Turnstile — secret key for server-side CAPTCHA verification.
# Get from: https://dash.cloudflare.com/?to=/:account/turnstile
# The public site_key goes in settings.yaml under turnstile.site_key.
TURNSTILE_SECRET_KEY=

# SMTP settings for the access request form email.
# Works with any SMTP server: Gmail (with app password), Mailgun, Postfix, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Your Name <noreply@yourdomain.com>"

# Destination email for access request notifications.
# Change this to whatever address you want to receive requests at.
ACCESS_TO_EMAIL=you@yourdomain.com

# Log verbosity: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info

# Pushover — instant push notifications for access requests (optional).
# Create an app at https://pushover.net/apps/build to get an app token.
# Your user key is on your Pushover dashboard at https://pushover.net/
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=
