# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.
#
# Service URLs (internal LAN addresses) stay in settings.yaml.
# All API keys and credentials live here so secrets are never on disk in plain YAML.

# ── Tautulli ──────────────────────────────────────────────────
# Settings > Web Interface > API Key in Tautulli.
TAUTULLI_API_KEY=

# ── Overseerr / Jellyseerr ────────────────────────────────────
# Settings > General > API Key in Overseerr.
OVERSEERR_API_KEY=

# ── SABnzbd ───────────────────────────────────────────────────
# Config > General > API Key in SABnzbd.
SABNZBD_API_KEY=

# ── TMDB ──────────────────────────────────────────────────────
# Free API key from https://www.themoviedb.org/settings/api
# Used to fetch rotating movie backdrop images on the home page.
TMDB_API_KEY=

# ── Radarr ────────────────────────────────────────────────────
# Settings > General > Security > API Key in Radarr.
RADARR_API_KEY=

# ── Sonarr ────────────────────────────────────────────────────
# Settings > General > Security > API Key in Sonarr.
SONARR_API_KEY=

# ── qBittorrent ───────────────────────────────────────────────
# Leave blank if qBittorrent is configured to bypass auth for localhost.
QBITTORRENT_USERNAME=
QBITTORRENT_PASSWORD=

# ── Cloudflare Turnstile ──────────────────────────────────────
# Secret key for server-side CAPTCHA verification.
# Get from: https://dash.cloudflare.com/?to=/:account/turnstile
# The public site_key goes in settings.yaml under turnstile.site_key.
TURNSTILE_SECRET_KEY=

# ── SMTP ──────────────────────────────────────────────────────
# Email delivery for the access request form.
# Works with any SMTP server: Gmail (with app password), Mailgun, Postfix, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Your Name <noreply@yourdomain.com>"

# Destination address for access request notifications.
ACCESS_TO_EMAIL=you@yourdomain.com

# ── Pushover ──────────────────────────────────────────────────
# Instant push notifications for access requests (optional).
# Create an app at https://pushover.net/apps/build to get an app token.
# Your user key is on your Pushover dashboard at https://pushover.net/
PUSHOVER_APP_TOKEN=
PUSHOVER_USER_KEY=

# ── Server Metrics ────────────────────────────────────────────
# Password to access the /server metrics page.
# Leave blank to disable auth (not recommended for public-facing sites).
METRICS_PASSWORD=

# ── Logging ───────────────────────────────────────────────────
# Log verbosity: trace | debug | info | warn | error (default: info)
LOG_LEVEL=info
